const { Pool } = require('pg');
require('dotenv').config();

const pool = new Pool({
  host:     process.env.DB_HOST     || 'localhost',
  port:     process.env.DB_PORT     || 5432,
  database: process.env.DB_NAME     || 'karrodb',
  user:     process.env.DB_USER     || 'postgres',
  password: process.env.DB_PASSWORD || '',
});

async function initDB() {
  // Users table
  await pool.query(`
    CREATE TABLE IF NOT EXISTS users (
      id          VARCHAR(20)  PRIMARY KEY,
      name        VARCHAR(255) NOT NULL,
      wins        INTEGER      DEFAULT 0,
      total_games INTEGER      DEFAULT 0,
      best_pct    INTEGER      DEFAULT 0,
      prizes      TEXT[]       DEFAULT '{}',
      level       VARCHAR(100) DEFAULT 'Yangi o''quvchi',
      last_played BIGINT,
      created_at  BIGINT       DEFAULT EXTRACT(EPOCH FROM NOW()) * 1000
    )
  `);

  // Counter table (for auto-ID)
  await pool.query(`
    CREATE TABLE IF NOT EXISTS counters (
      key   VARCHAR(50) PRIMARY KEY,
      value INTEGER     DEFAULT 0
    )
  `);
  await pool.query(`
    INSERT INTO counters (key, value) VALUES ('nextId', 0)
    ON CONFLICT (key) DO NOTHING
  `);

  // Results table
  await pool.query(`
    CREATE TABLE IF NOT EXISTS results (
      id               SERIAL PRIMARY KEY,
      participant_id   VARCHAR(20)  REFERENCES users(id),
      participant_name VARCHAR(255),
      mode             VARCHAR(10),
      score            INTEGER,
      total            INTEGER,
      pct              INTEGER,
      max_streak       INTEGER,
      date             BIGINT
    )
  `);

  console.log('✅ PostgreSQL ulandi. Jadvallar tayyor.');
}

module.exports = { pool, initDB };
