const express = require('express');
const { pool } = require('./db');
const router = express.Router();

// ─── HELPER: Increment counter ────────────────────────────────────
async function nextId() {
  const res = await pool.query(
    `UPDATE counters SET value = value + 1 WHERE key = 'nextId' RETURNING value`
  );
  return res.rows[0].value;
}

// ─── HELPER: Compute prizes ───────────────────────────────────────
function computePrizes(existing = [], user, pct, mode, maxStreak) {
  const e = new Set(existing);
  const wins = user.wins + (pct >= 70 ? 1 : 0);
  e.add('first_game');
  if (pct >= 70) e.add('first_win');
  if (wins >= 3 && pct >= 75) e.add('silver');
  if (wins >= 5 && pct >= 80) e.add('gold');
  if (wins >= 10 && pct >= 90) e.add('diamond');
  if (wins >= 21) e.add('legend');
  if (maxStreak >= 5) e.add('streak_5');
  if (mode !== 'all' && pct === 100) e.add('perfect_table');
  if (mode === 'all' && pct === 100) e.add('all_tables');
  return [...e];
}

function getLevel(wins) {
  const levels = [
    { min: 0,  title: "Yangi o'quvchi" },
    { min: 1,  title: "O'quvchi" },
    { min: 3,  title: 'Aqlli' },
    { min: 6,  title: 'Mohir' },
    { min: 11, title: 'Chempion' },
    { min: 21, title: 'Afsonaviy' },
  ];
  return [...levels].reverse().find(l => wins >= l.min)?.title || "Yangi o'quvchi";
}

// ════════════════════════════════════════════════════════════════
//  USERS
// ════════════════════════════════════════════════════════════════

// POST /api/users — ro'yxatdan o'tish
router.post('/users', async (req, res) => {
  const { name } = req.body;
  if (!name || !name.trim()) {
    return res.status(400).json({ error: 'name maydoni majburiy' });
  }

  try {
    const num = await nextId();
    const id  = `DH-${String(num).padStart(3, '0')}`;
    const now = Date.now();

    const result = await pool.query(
      `INSERT INTO users (id, name, created_at)
       VALUES ($1, $2, $3)
       RETURNING *`,
      [id, name.trim(), now]
    );

    console.log(`[POST] Yangi foydalanuvchi: ${id} — ${name.trim()}`);
    return res.status(201).json({ user: dbUserToClient(result.rows[0]) });
  } catch (err) {
    console.error('[POST /users]', err.message);
    return res.status(500).json({ error: 'Server xatosi' });
  }
});

// GET /api/users — barcha foydalanuvchilar (admin)
router.get('/users', async (req, res) => {
  try {
    const result = await pool.query(`SELECT * FROM users ORDER BY created_at DESC`);
    return res.json({ users: result.rows.map(dbUserToClient) });
  } catch (err) {
    console.error('[GET /users]', err.message);
    return res.status(500).json({ error: 'Server xatosi' });
  }
});

// GET /api/users/:id — bitta foydalanuvchi
router.get('/users/:id', async (req, res) => {
  try {
    const result = await pool.query(`SELECT * FROM users WHERE id = $1`, [req.params.id]);
    if (!result.rows.length) return res.status(404).json({ error: 'Topilmadi' });
    return res.json({ user: dbUserToClient(result.rows[0]) });
  } catch (err) {
    return res.status(500).json({ error: 'Server xatosi' });
  }
});

// ════════════════════════════════════════════════════════════════
//  RESULTS
// ════════════════════════════════════════════════════════════════

// POST /api/results — o'yin natijasini saqlash
router.post('/results', async (req, res) => {
  const { participantId, participantName, mode, score, total, pct, maxStreak } = req.body;
  if (!participantId) return res.status(400).json({ error: 'participantId majburiy' });

  try {
    // Foydalanuvchini olish
    const uRes = await pool.query(`SELECT * FROM users WHERE id = $1`, [participantId]);
    if (!uRes.rows.length) return res.status(404).json({ error: 'Foydalanuvchi topilmadi' });
    const u = uRes.rows[0];

    const isWin   = pct >= 70;
    const newWins = u.wins + (isWin ? 1 : 0);
    const newGames = u.total_games + 1;
    const newBest  = Math.max(u.best_pct || 0, pct);
    const newPrizes = computePrizes(u.prizes || [], { wins: u.wins }, pct, mode, maxStreak);
    const newLevel  = getLevel(newWins);
    const now       = Date.now();

    // Foydalanuvchini yangilash
    await pool.query(
      `UPDATE users SET wins=$1, total_games=$2, best_pct=$3, prizes=$4, level=$5, last_played=$6 WHERE id=$7`,
      [newWins, newGames, newBest, newPrizes, newLevel, now, participantId]
    );

    // Natijani saqlash
    const rRes = await pool.query(
      `INSERT INTO results (participant_id, participant_name, mode, score, total, pct, max_streak, date)
       VALUES ($1,$2,$3,$4,$5,$6,$7,$8) RETURNING *`,
      [participantId, participantName, mode, score, total, pct, maxStreak, now]
    );

    const updatedUser = await pool.query(`SELECT * FROM users WHERE id=$1`, [participantId]);

    console.log(`[POST] Natija: ${participantId} → ${pct}% (${mode})`);
    return res.status(201).json({
      result: dbResultToClient(rRes.rows[0]),
      user:   dbUserToClient(updatedUser.rows[0]),
    });
  } catch (err) {
    console.error('[POST /results]', err.message);
    return res.status(500).json({ error: 'Server xatosi' });
  }
});

// GET /api/results — barcha natijalar (admin)
router.get('/results', async (req, res) => {
  try {
    const { userId } = req.query;
    let q = `SELECT * FROM results ORDER BY date DESC`;
    let params = [];
    if (userId) {
      q = `SELECT * FROM results WHERE participant_id=$1 ORDER BY date DESC`;
      params = [userId];
    }
    const result = await pool.query(q, params);
    return res.json({ results: result.rows.map(dbResultToClient) });
  } catch (err) {
    return res.status(500).json({ error: 'Server xatosi' });
  }
});

// ─── DB row → client object ───────────────────────────────────────
function dbUserToClient(row) {
  return {
    id:          row.id,
    name:        row.name,
    wins:        row.wins,
    totalGames:  row.total_games,
    bestPct:     row.best_pct,
    prizes:      row.prizes || [],
    level:       row.level,
    lastPlayed:  row.last_played,
    registeredAt: row.created_at,
  };
}

function dbResultToClient(row) {
  return {
    id:              row.id,
    participantId:   row.participant_id,
    participantName: row.participant_name,
    mode:            row.mode,
    score:           row.score,
    total:           row.total,
    pct:             row.pct,
    maxStreak:       row.max_streak,
    date:            row.date,
  };
}

module.exports = router;
